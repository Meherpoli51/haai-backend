# ── Copy this to .env and fill in your values ──
# NEVER commit .env to git

# Anthropic — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# Supabase — get from supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxx

# Allowed frontend origins (comma separated, no trailing slash)
# Add your Netlify URL here
ALLOWED_ORIGINS=https://your-haai-site.netlify.app,https://haai.in

# Admin secret — used for /api/admin/topup (set any strong random string)
ADMIN_SECRET=change-this-to-something-strong-and-random

# Port (Railway sets this automatically — don't change)
PORT=3000
